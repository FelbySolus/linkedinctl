{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "browser/dist",
    "rootDir": "browser/src",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["browser/src/**/*.ts"]
}
